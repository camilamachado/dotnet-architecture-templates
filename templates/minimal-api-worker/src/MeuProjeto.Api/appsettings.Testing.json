{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Error",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "%TEMP%/logs/meuprojeto-log-tests.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "JwtSettings": {
    "Issuer": "MeuProjeto-Issuer-Testing",
    "SecurityKey": "MeuProjeto_Secret_Key_2026_Testing_High_Security_Token",
    "ExpirationHours": 12
  }
}
